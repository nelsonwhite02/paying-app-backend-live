# ==========================================================
# INIT PAYMENT (FLUTTER → BACKEND)
# ==========================================================

@router.post("/init")
def init_payment(payload: PaystackInitRequest):
    # print("🚨🚨🚨 INIT ROUTE HIT 🚨🚨🚨")
    if payload.amount <= 0:
        raise HTTPException(status_code=400, detail="Invalid amount")

    # reference = f"FUND-{uuid.uuid4().hex}"
    reference = str(uuid.uuid4())
    print("🔥 INIT CALLED")
    print("🧾 GENERATED REFERENCE:", reference)

    response = requests.post(
        PAYSTACK_INIT_URL,
        headers=HEADERS,
        json={
            "email": payload.email,
            "amount": int(payload.amount * 100),  # Kobo
            "reference": reference,
            "metadata": {
                "user_id": payload.user_id,
                "purpose": "wallet_funding",
            },
        },
        timeout=30,
    )

    data = response.json()

    if not data.get("status"):
        raise HTTPException(
            status_code=400,
            detail=data.get("message", "Paystack init failed"),
        )
    # print("💥 PAYSTACK INIT RESPONSE:", data)

    # 📝 Save pending transaction
    # insert_result = transactions_collection.insert_one({
    transactions_collection.insert_one({
        "reference": reference,
        "user_id": payload.user_id,
        "amount": payload.amount,
        "type": "wallet_funding",
        "status": "pending",
        "created_at": datetime.utcnow(),
    })
    # print("✅ INSERTED ID:", insert_result.inserted_id)

    # Immediately confirm it exists
    check_tx = transactions_collection.find_one({"reference": reference})
    # print("🔎 CHECK AFTER INSERT:", check_tx)
    # print("✅ TRANSACTION SAVED TO DB")
    return {
        "checkout_url": data["data"]["authorization_url"],
        "reference": reference,
    }

