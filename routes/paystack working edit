# HELPERS
# ==========================================================

def payment_already_processed(reference: str) -> bool:
    tx = transactions_collection.find_one({"reference": reference})
    return tx and tx["status"] == "success"

def credit_wallet(user_id: str, amount: float, reference: str):
    wallets_collection.find_one_and_update(
        {"_id": user_id},
        {
            "$inc": {"balance": amount},
            "$setOnInsert": {"created_at": datetime.utcnow()},
        },
        upsert=True,
        return_document=ReturnDocument.AFTER,
    )

    transactions_collection.update_one(
        {"reference": reference},
        {
            "$set": {
                "status": "success",
                "credited_at": datetime.utcnow(),
            }
        },
    )

    print(f"✅ Wallet credited ₦{amount} | user={user_id}")

def get_wallet_balance(user_id: str) -> float:
    wallet = wallets_collection.find_one({"_id": user_id})
    return wallet.get("balance", 0.0) if wallet else 0.0
