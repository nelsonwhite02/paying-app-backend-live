@router.get("/verify/{reference}")
def verify_payment(reference: str):
    print("🔎 VERIFY CALLED")
    print("🔎 REFERENCE RECEIVED:", reference)
    tx = transactions_collection.find_one({"reference": reference})

    if not tx:
        raise HTTPException(status_code=404, detail="Transaction not found")

    if tx["status"] == "success":
        return {
            "status": "already_verified",
            "balance": get_wallet_balance(tx["user_id"]),
        }

    try:
        response = requests.get(
            f"{PAYSTACK_VERIFY_URL}{reference}",
            headers=HEADERS,
            timeout=30,
        )
        response.raise_for_status()
        data = response.json()
    except requests.RequestException:
        raise HTTPException(
            status_code=500,
            detail="Payment verification service unavailable"
        )

    if not data.get("status"):
        raise HTTPException(status_code=400, detail="Verification failed")

    paystack_data = data["data"]

    if paystack_data["status"] != "success":
        raise HTTPException(status_code=400, detail="Payment not successful")

    amount = paystack_data["amount"] / 100
    user_id = paystack_data["metadata"]["user_id"]
    print("USER ID FROM PAYSTACK:", user_id)
    print("USER ID FROM TX:", tx["user_id"])

    # Validate user
    if user_id != tx["user_id"]:
        raise HTTPException(status_code=400, detail="User mismatch detected")

    # Validate amount
    if amount != tx["amount"]:
        raise HTTPException(status_code=400, detail="Amount mismatch detected")

    # Credit wallet
    credit_wallet(user_id, amount, reference)

    # Update transaction status
    transactions_collection.update_one(
        {"reference": reference},
        {"$set": {"status": "success"}}
    )

    # 🔥 ADD LEDGER ENTRY (Wallet History)
    # transactions_collection.insert_one({
    #     "user_id": user_id,
    #     "title": "Wallet Funding",
    #     "amount": amount,
    #     "type": "credit",
    #     "status": "success",
    #     "reference": reference,
    #     "created_at": datetime.utcnow()
    # })

    return {
        "status": "success",
        "amount": amount,
        "balance": get_wallet_balance(user_id),
    }


