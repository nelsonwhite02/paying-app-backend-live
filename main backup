@app.get("/ledger")
def get_ledger(user=Depends(get_current_user)):
    user_id = user["user_id"]

    txs = list(
        transactions_collection.find({"user_id": user_id}).sort("created_at", -1)
    )

    transactions = []
    for tx in txs:
        transactions.append({
            "reference": tx.get("reference"),
            "title": tx.get("title"),
            "network": tx.get("network", ""),
            "phone": tx.get("phone", ""),
            "plan_name": tx.get("plan_name", ""),
            "amount": tx.get("amount"),
            "date": tx.get("created_at").isoformat(),
            "type": tx.get("type", "credit"),
            "status": tx.get("status", "success")
        })

    return {"transactions": transactions}


