# 📞 BUY AIRTIME
# ======================================================
class BuyAirtimeRequest(BaseModel):
    network: str
    phone: str
    amount: float


@app.post("/buy-airtime")
def buy_airtime(req: BuyAirtimeRequest, user=Depends(get_current_user)):

    user_id = user["user_id"]
    amount = float(req.amount)

    wallet = wallets_collection.find_one({"_id": user_id})

    if not wallet or wallet["balance"] < amount:
        raise HTTPException(status_code=400, detail="Insufficient funds")

    reference = "airtime_" + os.urandom(6).hex()

    wallets_collection.update_one(
        {"_id": user_id},
        {"$inc": {"balance": -amount}}
    )

    payload = {
        "request_id": reference,
        "serviceID": req.network,
        "amount": amount,
        "phone": req.phone
    }

    vt = requests.post(
        "https://sandbox.vtpass.com/api/pay",
        json=payload,
        headers=HEADERS
    ).json()

    success = vt.get("code") == "000"

    if success:
        transactions_collection.insert_one({
            "user_id": user_id,
            "reference": reference,
            "amount": amount,
            "type": "debit",
            "network": req.network,
            "phone": req.phone,
            "plan_name": "Airtime",
            "status": "success",
            "created_at": datetime.utcnow()
        })
        return {"status": "success"}

    # refund
    wallets_collection.update_one(
        {"_id": user_id},
        {"$inc": {"balance": amount}}
    )

    return {"status": "failed"}


