class BuyEducationRequest(BaseModel):
    user_id: str
    service: str          # waec, neco, jamb, nabteb
    variation_code: str
    phone: str
    quantity: int = 1

@app.post("/buy-education")
def buy_education(req: BuyEducationRequest, user=Depends(get_current_user)):

    try:
        user_id = user["user_id"]
        service_id = req.service.lower()

        print("🎓 STEP 1: Fetching variations")

        # 1️⃣ FETCH VARIATIONS
        r = requests.get(
            "https://sandbox.vtpass.com/api/service-variations",
            params={"serviceID": service_id},
            headers=HEADERS,
            timeout=20
        )

        data = r.json()
        variations = data.get("content", {}).get("variations", [])

        selected = next(
            (v for v in variations if v["variation_code"] == req.variation_code),
            None
        )

        if not selected:
            raise HTTPException(status_code=400, detail="Invalid variation")

        amount = float(selected["variation_amount"])
        total_amount = amount * req.quantity

        print("🎓 STEP 2: Wallet check")
        print("USER:", user_id)
        print("AMOUNT:", total_amount)

        # 2️⃣ WALLET CHECK
        wallet = wallets_collection.find_one({"_id": user_id})

        if not wallet:
            raise HTTPException(status_code=404, detail="Wallet not found")

        if wallet.get("balance", 0) < total_amount:
            raise HTTPException(status_code=400, detail="Insufficient funds")

        # 3️⃣ DEBIT WALLET
        reference = "edu_" + os.urandom(6).hex()

        wallets_collection.update_one(
            {"_id": user_id},
            {"$inc": {"balance": -total_amount}}
        )

        print("🎓 STEP 3: Wallet debited")

        # 4️⃣ CALL VTPASS
        print("🎓 STEP 4: Calling VTPASS")

        payload = {
            "request_id": reference,
            "serviceID": service_id,
            "billersCode": req.phone,
            "variation_code": req.variation_code,
            "amount": total_amount,
            "phone": req.phone,
            "quantity": req.quantity
        }

        response = requests.post(
            "https://sandbox.vtpass.com/api/pay",
            json=payload,
            headers=HEADERS,
            timeout=30
        )

        vt = response.json()
        print("🎓 VT RESPONSE:", vt)

        # 5️⃣ SUCCESS CHECK
        code = str(vt.get("code", "")).strip()
        desc = vt.get("response_description", "").strip().upper()

        is_success = (
            code == "000" or
            desc == "TRANSACTION SUCCESSFUL"
        )

        print("🎓 SUCCESS:", is_success)

        # ================= EXTRACT PINS / TOKENS =================
        pins = (
            vt.get("purchased_code")
            or vt.get("pins")
            or vt.get("content", {}).get("transactions", {}).get("pins")
        )

        print("🎓 PINS:", pins)

        # ================= SUCCESS =================
        if is_success:
            print("✅ Saving SUCCESS education transaction")

            transactions_collection.insert_one({
                "user_id": user_id,
                "reference": reference,
                "amount": total_amount,
                "type": "debit",
                "service": req.service,
                "phone": req.phone,
                "plan_name": selected.get("name", "Education Payment"),
                "quantity": req.quantity,
                "pins": pins,
                "status": "success",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "success",
                "reference": reference,
                "pins": pins,
                "amount": total_amount,
                "vtpass_response": vt
            }

        # ================= FAILURE =================
        else:
            print("❌ Education purchase failed → refunding")

            wallets_collection.update_one(
                {"_id": user_id},
                {"$inc": {"balance": total_amount}}
            )

            transactions_collection.insert_one({
                "user_id": user_id,
                "reference": reference,
                "amount": total_amount,
                "type": "debit",
                "service": req.service,
                "phone": req.phone,
                "plan_name": selected.get("name", "Education Payment"),
                "quantity": req.quantity,
                "status": "failed",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "failed",
                "message": vt.get("response_description", "Transaction failed"),
                "vtpass_response": vt
            }

    except Exception as e:
        print("🔥 EDUCATION ERROR:", str(e))
        raise HTTPException(status_code=500, detail=str(e))
