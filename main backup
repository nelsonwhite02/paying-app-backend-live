# 📺 BUY CABLE
# ======================================================
class BuyCableRequest(BaseModel):
    service: str
    smartcard_number: str
    variation_code: str
    phone: str


@app.post("/buy-cable")
def buy_cable(req: BuyCableRequest, user=Depends(get_current_user)):

    try:
        user_id = user["user_id"]

        print("📺 STEP 1: Fetching cable plans")

        # 1️⃣ FETCH PLANS
        r = requests.get(
            "https://sandbox.vtpass.com/api/service-variations",
            params={"serviceID": req.service},
            headers=HEADERS,
            timeout=20
        )

        variations = r.json().get("content", {}).get("variations", [])

        selected = next(
            (v for v in variations if v["variation_code"] == req.variation_code),
            None
        )

        if not selected:
            raise HTTPException(status_code=400, detail="Invalid bouquet")

        amount = float(selected["variation_amount"])

        # ================= WALLET CHECK =================
        wallet = wallets_collection.find_one({"_id": user_id})

        print("📺 STEP 2: Wallet check")
        print("USER:", user_id)
        print("WALLET:", wallet)
        print("AMOUNT:", amount)

        if not wallet:
            raise HTTPException(status_code=404, detail="Wallet not found")

        if wallet.get("balance", 0) < amount:
            raise HTTPException(status_code=400, detail="Insufficient funds")

        # ================= DEBIT WALLET =================
        reference = "cable_" + os.urandom(6).hex()

        wallets_collection.update_one(
            {"_id": user_id},
            {"$inc": {"balance": -amount}}
        )

        print("📺 STEP 3: Wallet debited")

        # ================= CALL VTPASS =================
        print("📺 STEP 4: Calling VTPASS")

        payload = {
            "request_id": reference,
            "serviceID": req.service,
            "billersCode": req.smartcard_number,
            "variation_code": req.variation_code,
            "amount": amount,
            "phone": req.phone
        }

        response = requests.post(
            "https://sandbox.vtpass.com/api/pay",
            json=payload,
            headers=HEADERS,
            timeout=30
        )

        vt = response.json()
        print("📺 VT RESPONSE:", vt)

        # ================= CHECK SUCCESS =================
        code = str(vt.get("code", "")).strip()
        desc = vt.get("response_description", "").strip().upper()

        is_success = (
            code == "000" or
            desc == "TRANSACTION SUCCESSFUL"
        )

        print("📺 SUCCESS:", is_success)

        # ================= SUCCESS =================
        if is_success:
            print("✅ Saving SUCCESS cable transaction")

            transactions_collection.insert_one({
                "user_id": user_id,
                "reference": reference,
                "amount": amount,
                "type": "debit",
                "service": req.service,
                "smartcard_number": req.smartcard_number,
                "plan_name": selected.get("name"),
                "status": "success",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "success",
                "reference": reference,
                "plan": selected.get("name"),
                "amount": amount,
                "vtpass_response": vt
            }

        # ================= FAILURE =================
        else:
            print("❌ Cable failed → refunding wallet")

            # REFUND
            wallets_collection.update_one(
                {"_id": user_id},
                {"$inc": {"balance": amount}}
            )

            transactions_collection.insert_one({
                "user_id": user_id,
                "reference": reference,
                "amount": amount,
                "type": "debit",
                "service": req.service,
                "smartcard_number": req.smartcard_number,
                "plan_name": selected.get("name"),
                "status": "failed",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "failed",
                "message": vt.get("response_description", "Transaction failed"),
                "vtpass_response": vt
            }

    except Exception as e:
        print("🔥 CABLE ERROR:", str(e))
        raise HTTPException(status_code=500, detail=str(e))


