# ======================================================
# 📞 BUY AIRTIME (VTPASS)
# ======================================================

class BuyAirtimeRequest(BaseModel):
    user_id: str
    network: str   # mtn, glo, airtel, 9mobile
    phone: str
    amount: float


@app.post("/buy-airtime")
def buy_airtime(req: BuyAirtimeRequest):

    service_id = f"{req.network.lower()}"

    try:
        print("📞 STEP 1: Airtime request received")

        amount = float(req.amount)

        if amount <= 0:
            raise HTTPException(status_code=400, detail="Invalid amount")

        # 2️⃣ CHECK WALLET
        wallet = wallets_collection.find_one({"_id": req.user_id})

        print("📞 STEP 2: Wallet check")
        print("USER:", req.user_id)
        print("WALLET:", wallet)
        print("AMOUNT:", amount)

        if not wallet:
            raise HTTPException(status_code=404, detail="Wallet not found")

        balance = wallet.get("balance", 0)

        if balance < amount:
            raise HTTPException(status_code=400, detail="Insufficient funds")

        # 3️⃣ DEBIT WALLET
        reference = "airtime_" + os.urandom(6).hex()

        wallets_collection.update_one(
            {"_id": req.user_id},
            {"$inc": {"balance": -amount}}
        )

        print("📞 STEP 3: Wallet debited")

        # 4️⃣ CALL VTPASS
        print("📞 STEP 4: Calling VTPASS")

        payload = {
            "request_id": reference,
            "serviceID": service_id,   # e.g. mtn, glo
            "amount": amount,
            "phone": req.phone
        }

        response = requests.post(
            "https://sandbox.vtpass.com/api/pay",
            json=payload,
            headers=HEADERS,
            timeout=30
        )

        vt = response.json()

        print("📞 VT RESPONSE:", vt)

        # 5️⃣ CHECK SUCCESS
        code = str(vt.get("code", "")).strip()
        desc = vt.get("response_description", "").strip().upper()

        is_success = (
            code == "000" or
            desc == "TRANSACTION SUCCESSFUL"
        )

        print("📞 SUCCESS:", is_success)

        # ================= SUCCESS =================
        if is_success:
            print("✅ Saving SUCCESS airtime transaction")

            transactions_collection.insert_one({
                "user_id": req.user_id,
                "reference": reference,
                "amount": amount,
                "type": "debit",
                "network": req.network,
                "phone": req.phone,
                "plan_name": "Airtime Purchase",
                "status": "success",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "success",
                "reference": reference,
                "vtpass_response": vt
            }

        # ================= FAILURE =================
        else:
            print("❌ Airtime failed → refunding")

            # REFUND
            wallets_collection.update_one(
                {"_id": req.user_id},
                {"$inc": {"balance": amount}}
            )

            transactions_collection.insert_one({
                "user_id": req.user_id,
                "reference": reference,
                "amount": amount,
                "type": "debit",
                "network": req.network,
                "phone": req.phone,
                "plan_name": "Airtime Purchase",
                "status": "failed",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "failed",
                "message": vt.get("response_description", "Transaction failed"),
                "vtpass_response": vt
            }

    except Exception as e:
        print("🔥 ERROR:", str(e))
        raise HTTPException(status_code=500, detail=str(e))

