# 📺 VERIFY CABLE (SMARTCARD / IUC)
# ======================================================

class VerifyCableRequest(BaseModel):
    service: str        # dstv, gotv, startimes
    smartcard_number: str


@app.post("/verify-cable")
def verify_cable(req: VerifyCableRequest):

    try:
        print("📺 STEP 1: Verifying smartcard")

        payload = {
            "billersCode": req.smartcard_number,
            "serviceID": req.service
        }

        response = requests.post(
            "https://sandbox.vtpass.com/api/merchant-verify",
            json=payload,
            headers=HEADERS,
            timeout=20
        )

        data = response.json()
        print("📺 VERIFY RESPONSE:", data)

        if data.get("code") != "000":
            raise HTTPException(
                status_code=400,
                detail=data.get("response_description", "Verification failed")
            )

        return {
            "status": "success",
            "customer_name": data["content"]["Customer_Name"],
            "smartcard_number": req.smartcard_number,
            "service": req.service
        }

    except Exception as e:
        print("🔥 VERIFY ERROR:", str(e))
        raise HTTPException(status_code=500, detail=str(e))

