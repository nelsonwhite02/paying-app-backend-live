            params={"serviceID": service_id},
            headers=HEADERS,
            timeout=20
        )

        variations = r.json().get("content", {}).get("variations", [])

        selected = next(
            (v for v in variations if v["variation_code"] == req.variation_code),
            None
        )

        if not selected:
            raise HTTPException(status_code=400, detail="Invalid variation")

        amount = float(selected["variation_amount"])
        total_amount = amount * req.quantity

        print("🎓 STEP 2: Wallet check")

        # 2️⃣ CHECK WALLET
        wallet = wallets_collection.find_one({"_id": req.user_id})

        if not wallet:
            raise HTTPException(status_code=404, detail="Wallet not found")

        balance = wallet.get("balance", 0)

        if balance < total_amount:
            raise HTTPException(status_code=400, detail="Insufficient funds")

        print("🎓 STEP 3: Debit wallet")

        # 3️⃣ DEBIT WALLET
        reference = "edu_" + os.urandom(6).hex()

        wallets_collection.update_one(
            {"_id": req.user_id},
            {"$inc": {"balance": -total_amount}}
        )

        print("🎓 STEP 4: Calling VTPASS")

        # 4️⃣ CALL VTPASS
        payload = {
            "request_id": reference,
            "serviceID": service_id,
            "billersCode": req.phone,
            "variation_code": req.variation_code,
            "amount": total_amount,
            "phone": req.phone,
            "quantity": req.quantity
        }

        response = requests.post(
            "https://sandbox.vtpass.com/api/pay",
            json=payload,
            headers=HEADERS,
            timeout=30
        )

        vt = response.json()

        print("🎓 VT RESPONSE:", vt)

        # 5️⃣ CHECK SUCCESS
        code = str(vt.get("code", "")).strip()
        desc = vt.get("response_description", "").strip().upper()

        is_success = (
            code == "000" or
            desc == "TRANSACTION SUCCESSFUL"
        )

        print("🎓 SUCCESS:", is_success)

        # ================= SUCCESS =================
        if is_success:
            print("✅ Saving SUCCESS transaction")

            transactions_collection.insert_one({
                "user_id": req.user_id,
                "reference": reference,
                "amount": total_amount,
                "type": "debit",
                "service": req.service,
                "phone": req.phone,
                "plan_name": selected.get("name", "Education Payment"),
                "quantity": req.quantity,
                "status": "success",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "success",
                "reference": reference,
                "vtpass_response": vt
            }

        # ================= FAILURE =================
        else:
            print("❌ Transaction failed → refunding")

            # REFUND WALLET
            wallets_collection.update_one(
                {"_id": req.user_id},
                {"$inc": {"balance": total_amount}}
            )

            transactions_collection.insert_one({
                "user_id": req.user_id,
                "reference": reference,
                "amount": total_amount,
                "type": "debit",
                "service": req.service,
                "phone": req.phone,
                "plan_name": selected.get("name", "Education Payment"),
                "quantity": req.quantity,
                "status": "failed",
                "created_at": datetime.utcnow()
            })

            return {
                "status": "failed",
                "message": vt.get("response_description", "Transaction failed"),
                "vtpass_response": vt
            }

    except Exception as e:
        print("🔥 ERROR:", str(e))
        raise HTTPException(status_code=500, detail=str(e))
