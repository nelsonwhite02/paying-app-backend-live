            print("❌ Cable failed → refunding")

            wallets_collection.update_one(
                {"_id": req.user_id},
                {"$inc": {"balance": amount}}
            )

            transactions_collection.insert_one({
                "user_id": req.user_id,
                "reference": reference,
                "amount": amount,
                "type": "debit",
